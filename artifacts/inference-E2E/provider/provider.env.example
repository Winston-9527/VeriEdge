# Copy to provider.env and update values for each provider machine.

# Human-readable node id (for logs only)
PROVIDER_NODE_ID=provider-1

# Provider LAN IP used to validate first-shard placement.
PROVIDER_IP=127.0.0.1

# Exposed local endpoint for requester and health check.
EXO_ENDPOINT=http://127.0.0.1:52415

# Model id used by this provider node.
MODEL_ID=mlx-community/Qwen3-0.6B-8bit

# Hugging Face mirror endpoint for model downloading.
# For mainland China, hf-mirror is commonly used.
HF_ENDPOINT=https://hf-mirror.com

# Optional: exo repository directory.
# Used by manage_provider.sh lan-reset to build EXO_START_CMD.
EXO_REPO_DIR=~/repo/paper/third_party/exo

# Optional: exo runtime cache root used by nix run .
# Model files may already be managed outside EXO_HOME, for example under ~/.exo/models.
# EXO_HOME=~/.cache/exo-bcra

# Required: command used to start exo on this machine.
# Recommended default for this repo:
EXO_START_CMD="cd ~/repo/paper/third_party/exo && HF_ENDPOINT=https://hf-mirror.com EXO_HOME=~/.cache/exo-bcra DEBUG=9 nix run ."

# Launcher service for task dispatch.
LAUNCHER_HOST=0.0.0.0
LAUNCHER_PORT=18080
LAUNCHER_TIMEOUT_SEC=180
LAUNCHER_MAX_TOKENS=64

# Optional: wait for the provider to appear in /state and for the cluster
# to reach the expected size before returning from `manage_provider.sh start`.
# CLUSTER_JOIN_EXPECTED_NODE_COUNT=3
# CLUSTER_JOIN_TIMEOUT_SEC=180
# CLUSTER_JOIN_POLL_SEC=2

# Provider-side RSA keypair used to decrypt task keys.
PROVIDER_PRIVATE_KEY_PATH=artifacts/inference-E2E/provider/keys/provider_private.pem
PROVIDER_PUBLIC_KEY_PATH=artifacts/inference-E2E/provider/keys/provider_public.pem

# Optional extra flags for health probe timeout (seconds)
HEALTH_TIMEOUT_SEC=5
